<UserControl
	x:Class="ModrinthApp.Controls.ProjectCard"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<UserControl.Resources>
		<Style x:Key="TagBorderStyle" TargetType="Border">
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Padding" Value="8,3,8,3" />
			<Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
		</Style>
	</UserControl.Resources>

	<Border
		CornerRadius="8"
		Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
		BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
		BorderThickness="1"
		Padding="16 12">

		<Grid ColumnSpacing="16">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<!-- Project icon -->
			<Border
				x:Name="IconBorder"
				Width="64"
				Height="64"
				CornerRadius="10"
				Background="{ThemeResource AccentFillColorDefaultBrush}"
				VerticalAlignment="Center">
				<FontIcon
					x:Name="FallbackIcon"
					Glyph="&#xE7FC;"
					FontSize="28"
					Foreground="White"
					HorizontalAlignment="Center"
					VerticalAlignment="Center" />
			</Border>

			<!-- Title, author, description, tags -->
			<StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">

				<TextBlock
					x:Name="TitleText"
					FontSize="15"
					FontWeight="SemiBold"
					TextTrimming="CharacterEllipsis"
					MaxLines="1" />

				<StackPanel Orientation="Horizontal" Spacing="4">
					<TextBlock
						x:Name="AuthorText"
						Style="{StaticResource CaptionTextBlockStyle}"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					<FontIcon
						Glyph="&#xE8A7;"
						FontSize="10"
						Foreground="{ThemeResource TextFillColorTertiaryBrush}"
						VerticalAlignment="Center" />
				</StackPanel>

				<TextBlock
					x:Name="DescriptionText"
					Style="{StaticResource CaptionTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					TextTrimming="CharacterEllipsis"
					MaxLines="2"
					TextWrapping="Wrap" />

				<!-- Category tag pills — populated in code-behind -->
				<StackPanel x:Name="TagsPanel" Orientation="Horizontal" Spacing="4" />

			</StackPanel>

			<!-- Install button + stats -->
			<StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center" MinWidth="140">

				<Button
					x:Name="InstallButton"
					Style="{StaticResource AccentButtonStyle}"
					HorizontalAlignment="Right"
					Click="InstallButton_Click">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<FontIcon Glyph="&#xE710;" FontSize="12" />
						<TextBlock Text="Install" />
					</StackPanel>
				</Button>

				<StackPanel HorizontalAlignment="Right" Spacing="4">
					<StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<FontIcon Glyph="&#xE896;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
							<TextBlock x:Name="DownloadsText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
						</StackPanel>
						<StackPanel Orientation="Horizontal" Spacing="4">
							<FontIcon Glyph="&#xEB51;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
							<TextBlock x:Name="FollowsText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
						</StackPanel>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
						<FontIcon Glyph="&#xE121;" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
						<TextBlock x:Name="DateText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
					</StackPanel>
				</StackPanel>

			</StackPanel>
		</Grid>
	</Border>
</UserControl>
