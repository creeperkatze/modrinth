<Window
	x:Class="ModrinthApp.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Modrinth">

	<Window.SystemBackdrop>
		<MicaBackdrop Kind="Base" />
	</Window.SystemBackdrop>

	<Grid>
		<Grid.RowDefinitions>
			<!-- Custom title bar (drag region + logo + nav buttons) -->
			<RowDefinition Height="48" />
			<!-- Navigation rail + page content -->
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--
			Custom title bar — SetTitleBar() in code-behind makes this the drag region.
			Transparent background lets Mica show through; caption buttons float on the right.
		-->
		<Grid x:Name="AppTitleBar" Background="Transparent">
			<StackPanel
				Orientation="Horizontal"
				Spacing="4"
				Margin="12 0"
				VerticalAlignment="Center">

				<!-- Modrinth logo -->
				<Border
					Width="22"
					Height="22"
					CornerRadius="5"
					Background="{StaticResource ModrinthGreenBrush}">
					<FontIcon
						Glyph="&#xE7FC;"
						FontSize="12"
						Foreground="White"
						HorizontalAlignment="Center"
						VerticalAlignment="Center" />
				</Border>
				<TextBlock
					Text="modrinth app"
					FontWeight="SemiBold"
					FontSize="13"
					VerticalAlignment="Center"
					Margin="6 0 12 0" />

				<!-- Back / Forward -->
				<Button
					x:Name="BackButton"
					IsEnabled="False"
					Width="30"
					Height="30"
					Padding="0"
					Background="Transparent"
					BorderBrush="Transparent"
					Click="BackButton_Click"
					ToolTipService.ToolTip="Back">
					<FontIcon Glyph="&#xE76B;" FontSize="12" />
				</Button>
				<Button
					x:Name="ForwardButton"
					IsEnabled="False"
					Width="30"
					Height="30"
					Padding="0"
					Background="Transparent"
					BorderBrush="Transparent"
					Click="ForwardButton_Click"
					ToolTipService.ToolTip="Forward">
					<FontIcon Glyph="&#xE76C;" FontSize="12" />
				</Button>

				<!-- Current page breadcrumb -->
				<TextBlock
					x:Name="PageTitleText"
					Text="Home"
					VerticalAlignment="Center"
					Margin="8 0 0 0"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
			</StackPanel>
		</Grid>

		<!--
			Navigation rail + content.
			PaneDisplayMode="LeftCompact" → always icon-only, never expandable.
			IsPaneToggleButtonVisible="False" → no hamburger button.
			AlwaysShowHeader="False" → no duplicate title below our custom bar.
		-->
		<NavigationView
			Grid.Row="1"
			x:Name="NavView"
			PaneDisplayMode="LeftCompact"
			CompactPaneLength="48"
			IsPaneToggleButtonVisible="False"
			IsBackButtonVisible="Collapsed"
			IsSettingsVisible="True"
			AlwaysShowHeader="False"
			SelectionChanged="NavView_SelectionChanged"
			Loaded="NavView_Loaded">

			<NavigationView.MenuItems>
				<NavigationViewItem Tag="home" Content="Home">
					<NavigationViewItem.Icon>
						<FontIcon Glyph="&#xE80F;" />
					</NavigationViewItem.Icon>
				</NavigationViewItem>

				<NavigationViewItem Tag="library" Content="Library">
					<NavigationViewItem.Icon>
						<FontIcon Glyph="&#xE8B7;" />
					</NavigationViewItem.Icon>
				</NavigationViewItem>

				<NavigationViewItem Tag="browse" Content="Browse">
					<NavigationViewItem.Icon>
						<FontIcon Glyph="&#xE721;" />
					</NavigationViewItem.Icon>
				</NavigationViewItem>

				<NavigationViewItemSeparator />

				<NavigationViewItem Tag="worlds" Content="Worlds">
					<NavigationViewItem.Icon>
						<FontIcon Glyph="&#xECAA;" />
					</NavigationViewItem.Icon>
				</NavigationViewItem>

				<NavigationViewItem Tag="skins" Content="Skins">
					<NavigationViewItem.Icon>
						<FontIcon Glyph="&#xE77B;" />
					</NavigationViewItem.Icon>
				</NavigationViewItem>
			</NavigationView.MenuItems>

			<Frame
				x:Name="ContentFrame"
				IsNavigationStackEnabled="True"
				Navigated="ContentFrame_Navigated" />
		</NavigationView>
	</Grid>
</Window>
