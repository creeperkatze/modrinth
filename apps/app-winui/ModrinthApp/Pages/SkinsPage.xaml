<Page
	x:Class="ModrinthApp.Pages.SkinsPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<ScrollViewer>
		<StackPanel Padding="24 20" Spacing="24">

			<!-- Current skin card -->
			<Border
				CornerRadius="8"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				Padding="20">
				<Grid ColumnSpacing="20">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<!-- Skin preview placeholder (a real implementation would render the skin texture) -->
					<Border Width="80" Height="130" CornerRadius="4" Background="#1BD96A">
						<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
							<FontIcon Glyph="&#xE77B;" FontSize="36" Foreground="White" />
							<TextBlock
								Text="Preview"
								Style="{StaticResource CaptionTextBlockStyle}"
								Foreground="White"
								HorizontalAlignment="Center" />
						</StackPanel>
					</Border>

					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="12">
						<StackPanel Spacing="4">
							<TextBlock Text="Active Skin" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
							<TextBlock
								x:Name="ActiveSkinName"
								Text="Default Steve"
								Style="{StaticResource SubtitleTextBlockStyle}" />
						</StackPanel>

						<StackPanel Orientation="Horizontal" Spacing="8">
							<Button Content="Upload Custom Skin" Style="{StaticResource AccentButtonStyle}" Click="UploadSkin_Click" />
							<!-- TODO: Tauri IPC: add_and_equip_custom_skin -->
							<Button Content="Remove Skin" Click="RemoveSkin_Click" />
							<!-- TODO: Tauri IPC: unequip_skin -->
						</StackPanel>
					</StackPanel>
				</Grid>
			</Border>

			<!-- Skin library -->
			<StackPanel Spacing="12">
				<TextBlock Text="Skin Library" Style="{StaticResource SubtitleTextBlockStyle}" />

				<ItemsRepeater x:Name="SkinGrid" ItemsSource="{x:Bind Skins}">
					<ItemsRepeater.Layout>
						<UniformGridLayout
							MinItemWidth="120"
							MinColumnSpacing="12"
							MinRowSpacing="12" />
					</ItemsRepeater.Layout>
					<ItemsRepeater.ItemTemplate>
						<DataTemplate x:DataType="x:String">
							<Border
								CornerRadius="8"
								Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
								BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
								BorderThickness="1"
								Padding="12">
								<StackPanel Spacing="8" HorizontalAlignment="Center">
									<!-- Skin preview placeholder -->
									<Border
										Width="56"
										Height="90"
										CornerRadius="4"
										Background="#4A5568"
										HorizontalAlignment="Center">
										<FontIcon
											Glyph="&#xE77B;"
											FontSize="28"
											Foreground="White"
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>

									<TextBlock
										Text="{x:Bind}"
										Style="{StaticResource CaptionTextBlockStyle}"
										HorizontalAlignment="Center"
										TextAlignment="Center"
										TextTrimming="CharacterEllipsis"
										MaxLines="1" />

									<Button
										Content="Equip"
										HorizontalAlignment="Stretch">
										<!-- TODO: Tauri IPC: equip_skin(skinId) -->
									</Button>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsRepeater.ItemTemplate>
				</ItemsRepeater>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>
</Page>
