<Page
	x:Class="ModrinthApp.Pages.LibraryPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:models="using:ModrinthApp.Models"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Toolbar -->
		<Grid Padding="20 16" ColumnSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<AutoSuggestBox
				x:Name="SearchBox"
				PlaceholderText="Filter instances..."
				QueryIcon="Find"
				VerticalAlignment="Center"
				TextChanged="SearchBox_TextChanged" />

			<ComboBox
				Grid.Column="1"
				x:Name="SortCombo"
				SelectedIndex="0"
				VerticalAlignment="Center"
				SelectionChanged="SortCombo_SelectionChanged">
				<ComboBoxItem Content="Last Played" />
				<ComboBoxItem Content="Name (A–Z)" />
				<ComboBoxItem Content="Name (Z–A)" />
				<ComboBoxItem Content="Most Mods" />
			</ComboBox>

			<Button
				Grid.Column="2"
				Content="New Instance"
				Style="{StaticResource AccentButtonStyle}"
				VerticalAlignment="Center"
				Click="NewInstance_Click">
				<Button.ContentTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal" Spacing="8">
							<FontIcon Glyph="&#xE710;" FontSize="14" />
							<TextBlock Text="New Instance" />
						</StackPanel>
					</DataTemplate>
				</Button.ContentTemplate>
			</Button>
		</Grid>

		<!-- Instance list -->
		<ListView
			Grid.Row="1"
			x:Name="InstanceList"
			ItemsSource="{x:Bind FilteredInstances}"
			SelectionMode="None"
			Padding="8 0 8 8">
			<ListView.ItemContainerStyle>
				<Style TargetType="ListViewItem">
					<Setter Property="HorizontalContentAlignment" Value="Stretch" />
					<Setter Property="Padding" Value="4 2" />
				</Style>
			</ListView.ItemContainerStyle>
			<ListView.ItemTemplate>
				<DataTemplate x:DataType="models:Instance">
					<Border
						CornerRadius="8"
						Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
						BorderThickness="1"
						Padding="16 12">
						<Grid ColumnSpacing="16">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="48" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>

							<!-- Instance icon -->
							<Border
								Width="48"
								Height="48"
								CornerRadius="10">
								<Border.Background>
									<SolidColorBrush Color="{x:Bind LoaderColor}" />
								</Border.Background>
								<FontIcon
									Glyph="&#xE7FC;"
									FontSize="24"
									Foreground="White"
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>

							<!-- Name + details -->
							<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
								<TextBlock
									Text="{x:Bind Name}"
									Style="{StaticResource BodyStrongTextBlockStyle}"
									TextTrimming="CharacterEllipsis"
									MaxLines="1" />
								<TextBlock
									Text="{x:Bind SubtitleText}"
									Style="{StaticResource CaptionTextBlockStyle}"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
							</StackPanel>

							<!-- Last played -->
							<TextBlock
								Grid.Column="2"
								Text="{x:Bind LastPlayedText}"
								Style="{StaticResource CaptionTextBlockStyle}"
								Foreground="{ThemeResource TextFillColorSecondaryBrush}"
								VerticalAlignment="Center"
								MinWidth="80"
								TextAlignment="Right" />

							<!-- Play button -->
							<Button
								Grid.Column="3"
								VerticalAlignment="Center"
								Style="{StaticResource AccentButtonStyle}">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<FontIcon Glyph="&#xE768;" FontSize="12" />
									<TextBlock Text="Play" />
								</StackPanel>
								<!-- TODO: Click handler → Tauri IPC: profile_run(instance.Id) -->
							</Button>

							<!-- Options flyout -->
							<Button
								Grid.Column="4"
								VerticalAlignment="Center"
								Background="Transparent"
								BorderBrush="Transparent">
								<FontIcon Glyph="&#xE712;" FontSize="16" />
								<Button.Flyout>
									<MenuFlyout>
										<MenuFlyoutItem Text="Open Folder">
											<MenuFlyoutItem.Icon>
												<FontIcon Glyph="&#xE838;" />
											</MenuFlyoutItem.Icon>
											<!-- TODO: Tauri IPC: highlight_in_folder(profile_get_full_path(instance.Id)) -->
										</MenuFlyoutItem>
										<MenuFlyoutItem Text="Edit Instance">
											<MenuFlyoutItem.Icon>
												<FontIcon Glyph="&#xE70F;" />
											</MenuFlyoutItem.Icon>
										</MenuFlyoutItem>
										<MenuFlyoutItem Text="Duplicate">
											<MenuFlyoutItem.Icon>
												<FontIcon Glyph="&#xE8C8;" />
											</MenuFlyoutItem.Icon>
											<!-- TODO: Tauri IPC: profile_duplicate(instance.Id) -->
										</MenuFlyoutItem>
										<MenuFlyoutItem Text="Export as .mrpack">
											<MenuFlyoutItem.Icon>
												<FontIcon Glyph="&#xE896;" />
											</MenuFlyoutItem.Icon>
											<!-- TODO: Tauri IPC: profile_export_mrpack(instance.Id, ...) -->
										</MenuFlyoutItem>
										<MenuFlyoutSeparator />
										<MenuFlyoutItem Text="Delete Instance">
											<MenuFlyoutItem.Icon>
												<FontIcon Glyph="&#xE74D;" />
											</MenuFlyoutItem.Icon>
											<!-- TODO: Tauri IPC: profile_remove(instance.Id) -->
										</MenuFlyoutItem>
									</MenuFlyout>
								</Button.Flyout>
							</Button>
						</Grid>
					</Border>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>
	</Grid>
</Page>
