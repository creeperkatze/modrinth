<Page
	x:Class="ModrinthApp.Pages.SettingsPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<ScrollViewer>
		<StackPanel Padding="28 20 28 40" MaxWidth="720" Spacing="4">

			<!-- ══ Accounts ══ -->
			<TextBlock Text="Accounts" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 0 0 8" />

			<Border
				CornerRadius="8"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				Margin="0 0 0 16">
				<StackPanel>
					<!-- Minecraft account -->
					<Grid Padding="16 14" ColumnSpacing="14">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="36" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<Border Width="36" Height="36" CornerRadius="18" Background="#1BD96A">
							<FontIcon Glyph="&#xE77B;" FontSize="18" Foreground="White"
							          HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
							<TextBlock Text="Steve" FontWeight="SemiBold" />
							<TextBlock Text="Minecraft account  ·  Active" Style="{StaticResource CaptionTextBlockStyle}"
							           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						</StackPanel>
						<Button Grid.Column="2" Content="Sign out" VerticalAlignment="Center">
							<!-- TODO: Tauri IPC: remove_user(userId) -->
						</Button>
					</Grid>

					<Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16 0" />

					<!-- Add account button -->
					<Button Margin="16 12" Click="AddAccount_Click">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<FontIcon Glyph="&#xE710;" FontSize="14" />
							<TextBlock Text="Add Minecraft Account" />
						</StackPanel>
						<!-- TODO: Tauri IPC: login() -->
					</Button>
				</StackPanel>
			</Border>

			<!-- ══ Appearance ══ -->
			<TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 0 0 8" />

			<Border
				CornerRadius="8"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				Margin="0 0 0 16">
				<StackPanel>
					<Grid Padding="16 14" ColumnSpacing="14">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<StackPanel VerticalAlignment="Center" Spacing="2">
							<TextBlock Text="App Theme" FontWeight="SemiBold" />
							<TextBlock Text="Choose between light and dark mode, or follow the system setting."
							           Style="{StaticResource CaptionTextBlockStyle}"
							           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						</StackPanel>
						<ComboBox Grid.Column="1" x:Name="ThemeCombo" SelectedIndex="0" VerticalAlignment="Center"
						          SelectionChanged="ThemeCombo_SelectionChanged">
							<ComboBoxItem Content="System Default" />
							<ComboBoxItem Content="Light" />
							<ComboBoxItem Content="Dark" />
						</ComboBox>
					</Grid>
				</StackPanel>
			</Border>

			<!-- ══ Java ══ -->
			<TextBlock Text="Java" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 0 0 8" />

			<Border
				CornerRadius="8"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				Margin="0 0 0 16">
				<StackPanel>
					<!-- Java install list -->
					<Grid Padding="16 14" ColumnSpacing="14">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<StackPanel VerticalAlignment="Center" Spacing="2">
							<TextBlock Text="Java Installations" FontWeight="SemiBold" />
							<TextBlock Text="Java 21 (Temurin)  ·  C:\Program Files\Eclipse Adoptium\jdk-21"
							           Style="{StaticResource CaptionTextBlockStyle}"
							           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						</StackPanel>
						<Button Grid.Column="1" Content="Manage" VerticalAlignment="Center">
							<!-- TODO: Tauri IPC: get_java_versions(), jre_auto_install_java() -->
						</Button>
					</Grid>

					<Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16 0" />

					<!-- Max memory -->
					<Grid Padding="16 14" ColumnSpacing="14">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<StackPanel VerticalAlignment="Center" Spacing="2">
							<TextBlock Text="Maximum Memory" FontWeight="SemiBold" />
							<TextBlock Text="Allocated RAM per instance (unless overridden per-instance)."
							           Style="{StaticResource CaptionTextBlockStyle}"
							           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						</StackPanel>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
							<NumberBox
								x:Name="MemoryBox"
								Value="4096"
								Minimum="512"
								Maximum="65536"
								SpinButtonPlacementMode="Compact"
								SmallChange="512"
								Width="120" />
							<TextBlock Text="MB" VerticalAlignment="Center" />
						</StackPanel>
					</Grid>
				</StackPanel>
			</Border>

			<!-- ══ Storage ══ -->
			<TextBlock Text="Storage" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 0 0 8" />

			<Border
				CornerRadius="8"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				Margin="0 0 0 16">
				<Grid Padding="16 14" ColumnSpacing="14">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<StackPanel VerticalAlignment="Center" Spacing="2">
						<TextBlock Text="Data Directory" FontWeight="SemiBold" />
						<TextBlock
							x:Name="DataDirText"
							Text="%APPDATA%\com.modrinth.app"
							Style="{StaticResource CaptionTextBlockStyle}"
							Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					</StackPanel>
					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
						<Button Content="Change…" Click="ChangeDir_Click" />
						<!-- TODO: Tauri IPC: settings_set with new base_dir, then cancel_directory_change if cancelled -->
						<Button Content="Open" Click="OpenDir_Click">
							<!-- TODO: Tauri IPC: highlight_in_folder(dataDir) -->
						</Button>
					</StackPanel>
				</Grid>
			</Border>

			<!-- ══ Privacy ══ -->
			<TextBlock Text="Privacy" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 0 0 8" />

			<Border
				CornerRadius="8"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				Margin="0 0 0 16">
				<Grid Padding="16 14" ColumnSpacing="14">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<StackPanel VerticalAlignment="Center" Spacing="2">
						<TextBlock Text="Send Crash Reports" FontWeight="SemiBold" />
						<TextBlock Text="Anonymously send error data to help improve the launcher."
						           Style="{StaticResource CaptionTextBlockStyle}"
						           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					</StackPanel>
					<ToggleSwitch
						Grid.Column="1"
						IsOn="True"
						VerticalAlignment="Center"
						Toggled="Telemetry_Toggled">
						<!-- TODO: Tauri IPC: settings_set with updated telemetry field -->
					</ToggleSwitch>
				</Grid>
			</Border>

			<!-- ══ About ══ -->
			<TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 0 0 8" />

			<Border
				CornerRadius="8"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1">
				<StackPanel Padding="16 14" Spacing="4">
					<TextBlock Text="Modrinth App (WinUI)" FontWeight="SemiBold" />
					<TextBlock Text="Version 0.1.0-winui-experiment"
					           Style="{StaticResource CaptionTextBlockStyle}"
					           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					<HyperlinkButton Content="modrinth.com" Padding="0" />
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</Page>
