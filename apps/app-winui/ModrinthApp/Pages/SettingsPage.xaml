<Page
	x:Class="ModrinthApp.Pages.SettingsPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Page.Resources>
		<!-- Reusable card appearance matching WinUI's card controls -->
		<Style x:Key="SettingsCardBorderStyle" TargetType="Border">
			<Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
			<Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Padding" Value="16 14" />
		</Style>
	</Page.Resources>

	<ScrollViewer>
		<StackPanel Padding="28 20 28 40" MaxWidth="720" Spacing="4">

			<!-- Accounts -->
			<TextBlock Text="Accounts" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 0 0 8" />

			<Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0 0 0 4">
				<Expander.Header>
					<Grid ColumnSpacing="12" Margin="0 2">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<Border Width="32" Height="32" CornerRadius="16" Background="#1BD96A">
							<FontIcon Glyph="&#xE77B;" FontSize="16" Foreground="White"
							          HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
							<TextBlock Text="Steve" FontWeight="SemiBold" />
							<TextBlock Text="Minecraft account  ·  Active"
							           Style="{StaticResource CaptionTextBlockStyle}"
							           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						</StackPanel>
						<Button Grid.Column="2" Content="Sign out" VerticalAlignment="Center" />
					</Grid>
				</Expander.Header>
				<Border Style="{StaticResource SettingsCardBorderStyle}" Margin="0 4">
					<Grid ColumnSpacing="12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<FontIcon Glyph="&#xE710;" VerticalAlignment="Center" />
						<TextBlock Grid.Column="1" Text="Add another Minecraft account" VerticalAlignment="Center" FontWeight="SemiBold" />
						<Button Grid.Column="2" Content="Add account" Click="AddAccount_Click" />
					</Grid>
				</Border>
			</Expander>

			<!-- Appearance -->
			<TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 16 0 8" />

			<Border Style="{StaticResource SettingsCardBorderStyle}" Margin="0 0 0 4">
				<Grid ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<FontIcon Glyph="&#xE771;" VerticalAlignment="Center" />
					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
						<TextBlock Text="App Theme" FontWeight="SemiBold" />
						<TextBlock Text="Choose between light and dark mode, or follow the system setting."
						           Style="{StaticResource CaptionTextBlockStyle}"
						           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					</StackPanel>
					<ComboBox Grid.Column="2" x:Name="ThemeCombo" SelectedIndex="0" VerticalAlignment="Center"
					          SelectionChanged="ThemeCombo_SelectionChanged">
						<ComboBoxItem Content="System Default" />
						<ComboBoxItem Content="Light" />
						<ComboBoxItem Content="Dark" />
					</ComboBox>
				</Grid>
			</Border>

			<!-- Java -->
			<TextBlock Text="Java" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 16 0 8" />

			<Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0 0 0 4">
				<Expander.Header>
					<Grid ColumnSpacing="12" Margin="0 2">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<FontIcon Glyph="&#xECAA;" VerticalAlignment="Center" />
						<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
							<TextBlock Text="Java Installations" FontWeight="SemiBold" />
							<TextBlock Text="Java 21 (Temurin)  ·  C:\Program Files\Eclipse Adoptium\jdk-21"
							           Style="{StaticResource CaptionTextBlockStyle}"
							           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						</StackPanel>
						<Button Grid.Column="2" Content="Manage" VerticalAlignment="Center" />
					</Grid>
				</Expander.Header>
				<Border Style="{StaticResource SettingsCardBorderStyle}" Margin="0 4">
					<Grid ColumnSpacing="12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<FontIcon Glyph="&#xE950;" VerticalAlignment="Center" />
						<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
							<TextBlock Text="Maximum Memory" FontWeight="SemiBold" />
							<TextBlock Text="Allocated RAM per instance (unless overridden per-instance)."
							           Style="{StaticResource CaptionTextBlockStyle}"
							           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
						</StackPanel>
						<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
							<NumberBox
								x:Name="MemoryBox"
								Value="4096"
								Minimum="512"
								Maximum="65536"
								SpinButtonPlacementMode="Compact"
								SmallChange="512"
								Width="120" />
							<TextBlock Text="MB" VerticalAlignment="Center" />
						</StackPanel>
					</Grid>
				</Border>
			</Expander>

			<!-- Storage -->
			<TextBlock Text="Storage" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 16 0 8" />

			<Border Style="{StaticResource SettingsCardBorderStyle}" Margin="0 0 0 4">
				<Grid ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<FontIcon Glyph="&#xE838;" VerticalAlignment="Center" />
					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
						<TextBlock Text="Data Directory" FontWeight="SemiBold" />
						<TextBlock x:Name="DataDirText" Text="%APPDATA%\com.modrinth.app"
						           Style="{StaticResource CaptionTextBlockStyle}"
						           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					</StackPanel>
					<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
						<Button Content="Change…" Click="ChangeDir_Click" />
						<Button Content="Open" Click="OpenDir_Click" />
					</StackPanel>
				</Grid>
			</Border>

			<!-- Privacy -->
			<TextBlock Text="Privacy" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 16 0 8" />

			<Border Style="{StaticResource SettingsCardBorderStyle}" Margin="0 0 0 4">
				<Grid ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<FontIcon Glyph="&#xE8C8;" VerticalAlignment="Center" />
					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
						<TextBlock Text="Send Crash Reports" FontWeight="SemiBold" />
						<TextBlock Text="Anonymously send error data to help improve the launcher."
						           Style="{StaticResource CaptionTextBlockStyle}"
						           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					</StackPanel>
					<ToggleSwitch Grid.Column="2" IsOn="True" VerticalAlignment="Center" Toggled="Telemetry_Toggled" />
				</Grid>
			</Border>

			<!-- About -->
			<TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0 16 0 8" />

			<Border Style="{StaticResource SettingsCardBorderStyle}">
				<Grid ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<FontIcon Glyph="&#xE946;" VerticalAlignment="Center" />
					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
						<TextBlock Text="Modrinth App (WinUI)" FontWeight="SemiBold" />
						<TextBlock Text="Version 0.1.0-winui-experiment"
						           Style="{StaticResource CaptionTextBlockStyle}"
						           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
					</StackPanel>
					<HyperlinkButton Grid.Column="2" Content="modrinth.com" VerticalAlignment="Center" />
				</Grid>
			</Border>

		</StackPanel>
	</ScrollViewer>
</Page>
