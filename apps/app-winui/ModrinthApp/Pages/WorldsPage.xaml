<Page
	x:Class="ModrinthApp.Pages.WorldsPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:models="using:ModrinthApp.Models"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Toolbar -->
		<AutoSuggestBox
			x:Name="SearchBox"
			Margin="20 16"
			PlaceholderText="Filter worlds…"
			QueryIcon="Find"
			TextChanged="SearchBox_TextChanged" />

		<!-- Worlds list -->
		<ListView
			Grid.Row="1"
			ItemsSource="{x:Bind FilteredWorlds}"
			SelectionMode="None"
			Padding="8 0 8 8">
			<ListView.ItemContainerStyle>
				<Style TargetType="ListViewItem">
					<Setter Property="HorizontalContentAlignment" Value="Stretch" />
					<Setter Property="Padding" Value="4 3" />
				</Style>
			</ListView.ItemContainerStyle>
			<ListView.ItemTemplate>
				<DataTemplate x:DataType="models:World">
					<Border
						CornerRadius="8"
						Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
						BorderThickness="1"
						Padding="16 12">
						<Grid ColumnSpacing="16">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="48" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>

							<!-- World icon placeholder -->
							<Border Width="48" Height="48" CornerRadius="6" Background="#2D6A4F">
								<FontIcon
									Glyph="&#xECAA;"
									FontSize="24"
									Foreground="White"
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>

							<!-- World info -->
							<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
								<TextBlock
									Text="{x:Bind Name}"
									Style="{StaticResource BodyStrongTextBlockStyle}"
									TextTrimming="CharacterEllipsis"
									MaxLines="1" />
								<TextBlock
									Text="{x:Bind InstanceName}"
									Style="{StaticResource CaptionTextBlockStyle}"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
								<TextBlock
									Text="{x:Bind DetailText}"
									Style="{StaticResource CaptionTextBlockStyle}"
									Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
							</StackPanel>

							<!-- Last played -->
							<TextBlock
								Grid.Column="2"
								Text="{x:Bind LastPlayedText}"
								Style="{StaticResource CaptionTextBlockStyle}"
								Foreground="{ThemeResource TextFillColorSecondaryBrush}"
								VerticalAlignment="Center"
								MinWidth="72"
								TextAlignment="Right" />

							<!-- Play -->
							<Button
								Grid.Column="3"
								VerticalAlignment="Center"
								Style="{StaticResource AccentButtonStyle}">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<FontIcon Glyph="&#xE768;" FontSize="12" />
									<TextBlock Text="Play" />
								</StackPanel>
								<!-- TODO: Tauri IPC: start_join_singleplayer_world(world, instance.Id) -->
							</Button>

							<!-- Options -->
							<Button
								Grid.Column="4"
								VerticalAlignment="Center"
								Background="Transparent"
								BorderBrush="Transparent">
								<FontIcon Glyph="&#xE712;" FontSize="16" />
								<Button.Flyout>
									<MenuFlyout>
										<MenuFlyoutItem Text="Rename" />
										<!-- TODO: Tauri IPC: rename_world -->
										<MenuFlyoutItem Text="Backup" />
										<!-- TODO: Tauri IPC: backup_world -->
										<MenuFlyoutSeparator />
										<MenuFlyoutItem Text="Delete" />
										<!-- TODO: Tauri IPC: delete_world -->
									</MenuFlyout>
								</Button.Flyout>
							</Button>
						</Grid>
					</Border>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>
	</Grid>
</Page>
