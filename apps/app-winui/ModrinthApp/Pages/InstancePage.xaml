<Page
	x:Class="ModrinthApp.Pages.InstancePage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Instance header -->
		<Border
			Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
			BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
			BorderThickness="0 0 0 1"
			Padding="20 14">
			<Grid ColumnSpacing="16">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<!-- Icon -->
				<Border
					Width="52"
					Height="52"
					CornerRadius="10"
					x:Name="InstanceIconBorder">
					<Border.Background>
						<SolidColorBrush x:Name="InstanceIconColor" Color="#1BD96A" />
					</Border.Background>
					<FontIcon Glyph="&#xE7FC;" FontSize="26" Foreground="White"
					          HorizontalAlignment="Center" VerticalAlignment="Center" />
				</Border>

				<!-- Name + subtitle -->
				<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
					<TextBlock x:Name="InstanceNameText" Text="Instance Name"
					           Style="{StaticResource SubtitleTextBlockStyle}" />
					<TextBlock x:Name="InstanceSubtitleText" Text="Loader  ·  Version  ·  N mods"
					           Style="{StaticResource CaptionTextBlockStyle}"
					           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
				</StackPanel>

				<!-- Actions -->
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<Button Style="{StaticResource AccentButtonStyle}">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<FontIcon Glyph="&#xE768;" FontSize="14" />
							<TextBlock Text="Play" />
						</StackPanel>
						<!-- TODO: Tauri IPC: profile_run(instanceId) -->
					</Button>
					<Button>
						<StackPanel Orientation="Horizontal" Spacing="6">
							<FontIcon Glyph="&#xE838;" FontSize="14" />
							<TextBlock Text="Folder" />
						</StackPanel>
						<!-- TODO: Tauri IPC: highlight_in_folder(profile_get_full_path(instanceId)) -->
					</Button>
					<Button>
						<FontIcon Glyph="&#xE70F;" FontSize="14" />
						<!-- TODO: Open edit instance dialog -->
					</Button>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Pivot tabs: Mods / Worlds / Files / Logs -->
		<Pivot Grid.Row="1" Margin="12 0">

			<PivotItem Header="Mods">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<Grid Padding="0 12 0 8" ColumnSpacing="8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<AutoSuggestBox PlaceholderText="Filter mods…" QueryIcon="Find" />
						<Button Grid.Column="1" Content="Add Mods" Style="{StaticResource AccentButtonStyle}">
							<!-- TODO: Navigate to Browse page pre-filtered for this instance's loader/version -->
						</Button>
					</Grid>

					<ListView
						Grid.Row="1"
						x:Name="ModList"
						SelectionMode="None">
						<ListView.ItemContainerStyle>
							<Style TargetType="ListViewItem">
								<Setter Property="HorizontalContentAlignment" Value="Stretch" />
								<Setter Property="Padding" Value="4 2" />
							</Style>
						</ListView.ItemContainerStyle>
						<!-- TODO: Populate from Tauri IPC: profile_get_content_items(instanceId) -->

						<!-- Placeholder rows while not yet wired to backend -->
						<ListViewItem>
							<Border CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
							        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12 10">
								<Grid ColumnSpacing="12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="36" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<Border Width="36" Height="36" CornerRadius="6" Background="#1BD96A">
										<FontIcon Glyph="&#xE7FC;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
									</Border>
									<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
										<TextBlock Text="Sodium" FontWeight="SemiBold" />
										<TextBlock Text="by CaffeineMC  ·  mc1.21-0.6.8" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
									</StackPanel>
									<ToggleButton Grid.Column="2" Content="Enabled" VerticalAlignment="Center" IsChecked="True" />
									<Button Grid.Column="3" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center">
										<FontIcon Glyph="&#xE74D;" FontSize="14" />
									</Button>
								</Grid>
							</Border>
						</ListViewItem>

						<ListViewItem>
							<Border CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
							        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12 10">
								<Grid ColumnSpacing="12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="36" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<Border Width="36" Height="36" CornerRadius="6" Background="#4A5568">
										<FontIcon Glyph="&#xE7FC;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
									</Border>
									<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
										<TextBlock Text="Iris Shaders" FontWeight="SemiBold" />
										<TextBlock Text="by IrisShaders  ·  1.8.0+mc1.21.1" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
									</StackPanel>
									<ToggleButton Grid.Column="2" Content="Enabled" VerticalAlignment="Center" IsChecked="True" />
									<Button Grid.Column="3" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center">
										<FontIcon Glyph="&#xE74D;" FontSize="14" />
									</Button>
								</Grid>
							</Border>
						</ListViewItem>

					</ListView>
				</Grid>
			</PivotItem>

			<PivotItem Header="Worlds">
				<TextBlock
					Text="Worlds list — TODO: populate from Tauri IPC: get_profile_worlds(instanceId)"
					Style="{StaticResource CaptionTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Margin="0 16"
					TextWrapping="Wrap" />
			</PivotItem>

			<PivotItem Header="Files">
				<TextBlock
					Text="File browser — TODO: populate from Tauri IPC: profile_get_full_path(instanceId), then open OS file picker or custom tree view"
					Style="{StaticResource CaptionTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Margin="0 16"
					TextWrapping="Wrap" />
			</PivotItem>

			<PivotItem Header="Logs">
				<TextBlock
					Text="Log viewer — TODO: read game log from the instance's logs/ folder and display in a read-only TextBox with auto-scroll"
					Style="{StaticResource CaptionTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Margin="0 16"
					TextWrapping="Wrap" />
			</PivotItem>

		</Pivot>
	</Grid>
</Page>
