<Page
	x:Class="ModrinthApp.Pages.BrowsePage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:models="using:ModrinthApp.Models"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Search bar -->
		<AutoSuggestBox
			x:Name="SearchBox"
			Margin="20 16 20 0"
			PlaceholderText="Search mods, modpacks, resource packs, shaders…"
			QueryIcon="Find"
			QuerySubmitted="SearchBox_QuerySubmitted" />

		<!-- Category tabs + sort -->
		<Grid Grid.Row="1" Margin="20 12 20 0" ColumnSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<ScrollViewer
				HorizontalScrollMode="Enabled"
				VerticalScrollMode="Disabled"
				HorizontalScrollBarVisibility="Hidden">
				<StackPanel x:Name="CategoryPanel" Orientation="Horizontal" Spacing="6">
					<ToggleButton Content="Mods"           Tag="mod"          IsChecked="True"  Click="Category_Click" />
					<ToggleButton Content="Modpacks"       Tag="modpack"      IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Resource Packs" Tag="resourcepack" IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Shaders"        Tag="shader"       IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Datapacks"      Tag="datapack"     IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Plugins"        Tag="plugin"       IsChecked="False" Click="Category_Click" />
				</StackPanel>
			</ScrollViewer>

			<ComboBox
				Grid.Column="1"
				x:Name="SortCombo"
				SelectedIndex="0"
				SelectionChanged="SortCombo_SelectionChanged">
				<ComboBoxItem Content="Relevance" />
				<ComboBoxItem Content="Downloads" />
				<ComboBoxItem Content="Follows" />
				<ComboBoxItem Content="Newest" />
				<ComboBoxItem Content="Updated" />
			</ComboBox>
		</Grid>

		<!-- Results grid -->
		<ScrollViewer Grid.Row="2" Padding="20 12 20 20">
			<ItemsRepeater ItemsSource="{x:Bind SearchResults}">
				<ItemsRepeater.Layout>
					<UniformGridLayout
						MinItemWidth="300"
						MinColumnSpacing="12"
						MinRowSpacing="12" />
				</ItemsRepeater.Layout>
				<ItemsRepeater.ItemTemplate>
					<DataTemplate x:DataType="models:Project">
						<Border
							CornerRadius="8"
							Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
							BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
							BorderThickness="1"
							Padding="16">
							<Grid RowSpacing="8">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="*" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<!-- Header: icon + title + author -->
								<Grid ColumnSpacing="12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="44" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>

									<Border
										Width="44"
										Height="44"
										CornerRadius="8"
										Background="{ThemeResource AccentFillColorDefaultBrush}">
										<FontIcon
											Glyph="&#xE7FC;"
											FontSize="22"
											Foreground="White"
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>

									<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
										<TextBlock
											Text="{x:Bind Title}"
											FontWeight="SemiBold"
											TextTrimming="CharacterEllipsis"
											MaxLines="1" />
										<TextBlock
											Text="{x:Bind Author}"
											Style="{StaticResource CaptionTextBlockStyle}"
											Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
									</StackPanel>
								</Grid>

								<!-- Description -->
								<TextBlock
									Grid.Row="1"
									Text="{x:Bind Description}"
									Style="{StaticResource CaptionTextBlockStyle}"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									TextTrimming="CharacterEllipsis"
									MaxLines="3"
									TextWrapping="Wrap" />

								<!-- Footer: downloads + install button -->
								<Grid Grid.Row="2">
									<TextBlock
										Text="{x:Bind DownloadsFormatted}"
										Style="{StaticResource CaptionTextBlockStyle}"
										Foreground="{ThemeResource TextFillColorTertiaryBrush}"
										VerticalAlignment="Center" />
									<Button
										Content="Install"
										HorizontalAlignment="Right"
										Style="{StaticResource AccentButtonStyle}">
										<!-- TODO: Tauri IPC: profile_add_project_from_version or open version picker dialog -->
									</Button>
								</Grid>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsRepeater.ItemTemplate>
			</ItemsRepeater>
		</ScrollViewer>
	</Grid>
</Page>
