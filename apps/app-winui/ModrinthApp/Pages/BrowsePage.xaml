<Page
	x:Class="ModrinthApp.Pages.BrowsePage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:ModrinthApp.Controls"
	xmlns:modrinth="using:Modrinth.Models"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Search bar -->
		<AutoSuggestBox
			x:Name="SearchBox"
			Margin="20 16 20 0"
			PlaceholderText="Search mods, modpacks, resource packs, shaders…"
			QueryIcon="Find"
			QuerySubmitted="SearchBox_QuerySubmitted"
			TextChanged="SearchBox_TextChanged" />

		<!-- Category tabs + sort -->
		<Grid Grid.Row="1" Margin="20 12 20 0" ColumnSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<ScrollViewer
				HorizontalScrollMode="Enabled"
				VerticalScrollMode="Disabled"
				HorizontalScrollBarVisibility="Hidden">
				<StackPanel x:Name="CategoryPanel" Orientation="Horizontal" Spacing="6">
					<ToggleButton Content="Mods"           Tag="mod"          IsChecked="True"  Click="Category_Click" />
					<ToggleButton Content="Modpacks"       Tag="modpack"      IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Resource Packs" Tag="resourcepack" IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Shaders"        Tag="shader"       IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Datapacks"      Tag="datapack"     IsChecked="False" Click="Category_Click" />
					<ToggleButton Content="Plugins"        Tag="plugin"       IsChecked="False" Click="Category_Click" />
				</StackPanel>
			</ScrollViewer>

			<ComboBox
				Grid.Column="1"
				x:Name="SortCombo"
				SelectedIndex="0"
				SelectionChanged="SortCombo_SelectionChanged">
				<ComboBoxItem Content="Relevance" />
				<ComboBoxItem Content="Downloads" />
				<ComboBoxItem Content="Follows" />
				<ComboBoxItem Content="Newest" />
				<ComboBoxItem Content="Updated" />
			</ComboBox>
		</Grid>

		<!-- Results / loading / error area -->
		<Grid Grid.Row="2">

			<!-- Loading spinner -->
			<ProgressRing
				x:Name="LoadingRing"
				IsActive="True"
				Width="40"
				Height="40"
				HorizontalAlignment="Center"
				VerticalAlignment="Center" />

			<!-- Error message -->
			<TextBlock
				x:Name="ErrorText"
				Text="Could not load results. Check your connection and try again."
				Visibility="Collapsed"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Foreground="{ThemeResource TextFillColorSecondaryBrush}"
				TextAlignment="Center" />

			<!-- Results grid -->
			<ScrollViewer x:Name="ResultsScrollViewer" Padding="20 12 20 20" Visibility="Collapsed">
				<ItemsRepeater ItemsSource="{x:Bind SearchResults}">
					<ItemsRepeater.Layout>
						<StackLayout Spacing="8" />
					</ItemsRepeater.Layout>
					<ItemsRepeater.ItemTemplate>
						<DataTemplate x:DataType="modrinth:SearchResult">
							<controls:ProjectCard Hit="{x:Bind}" />
						</DataTemplate>
					</ItemsRepeater.ItemTemplate>
				</ItemsRepeater>
			</ScrollViewer>
		</Grid>
	</Grid>
</Page>
